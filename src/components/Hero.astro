---
interface Props {
  waLink: string;
}

const { waLink } = Astro.props;
---

<section class="relative min-h-screen flex items-center pt-16 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 bg-grid"></div>
  <div class="absolute -top-40 -right-40 w-[500px] h-[500px] bg-primary-container/20 rounded-full blur-[100px]"></div>
  <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] bg-secondary/10 rounded-full blur-[100px]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <!-- Badge -->
    <div data-reveal class="inline-flex items-center gap-2 bg-surface-container border border-outline-variant/20 rounded-full px-4 py-1.5 mb-8">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-secondary opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-secondary"></span>
      </span>
      <span class="text-sm text-on-surface-variant">&#10022; Disponible para proyectos</span>
    </div>

    <!-- H1 -->
    <h1 data-reveal class="font-heading text-5xl sm:text-6xl md:text-8xl font-bold tracking-tighter leading-[0.95] mb-6 max-w-5xl">
      Landing pages que
      <span class="gradient-text">convierten</span>
      visitantes en clientes.
    </h1>

    <!-- Subtitle -->
    <p data-reveal class="text-lg md:text-xl text-on-surface-variant max-w-2xl mb-10 leading-relaxed">
      Diseño y desarrollo landing pages profesionales para negocios
      locales en Lima y toda Latinoamérica. Con IA, en menos de 5 días.
    </p>

    <!-- Stats -->
    <div data-reveal class="flex gap-8 md:gap-12 mb-10">
      <div>
        <p class="text-3xl md:text-4xl font-heading font-bold text-on-surface">&lt; 5 días</p>
        <p class="text-sm text-outline mt-1">Entrega Veloz</p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-heading font-bold text-on-surface">100%</p>
        <p class="text-sm text-outline mt-1">Responsive</p>
      </div>
      <div>
        <p class="text-3xl md:text-4xl font-heading font-bold text-on-surface">3</p>
        <p class="text-sm text-outline mt-1">Revisiones</p>
      </div>
    </div>

    <!-- CTAs -->
    <div data-reveal class="flex flex-wrap gap-4">
      <a
        href="#proyectos"
        class="inline-flex items-center gap-2 bg-primary-container text-on-primary-container px-6 py-3 rounded-lg font-medium hover:brightness-110 transition-all"
      >
        Ver mis proyectos
      </a>
      <a
        href={waLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 border border-outline-variant text-on-surface px-6 py-3 rounded-lg font-medium hover:border-primary hover:text-primary transition-all"
      >
        Cotiza por WhatsApp &rarr;
      </a>
    </div>
  </div>
</section>
