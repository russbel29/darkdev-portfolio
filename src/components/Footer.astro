---
interface Props {
  brand: string;
  year: string;
}

const { brand, year } = Astro.props;
---

<footer class="py-12 border-t border-outline-variant/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <!-- Logo -->
      <a href="#" class="text-xl font-heading font-bold text-on-surface">
        {brand.slice(0, 4)}<span class="text-primary-container">{brand.slice(4)}</span>
      </a>

      <!-- Social links -->
      <div class="flex items-center gap-6">
        <a
          href="https://github.com/russbel29"
          target="_blank"
          rel="noopener noreferrer"
          class="text-on-surface-variant hover:text-primary transition-colors text-sm"
        >
          Github
        </a>
        <a
          href="https://www.linkedin.com/in/russbel-celis-celestino-4285b52ba/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-on-surface-variant hover:text-primary transition-colors text-sm"
        >
          LinkedIn
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-sm text-outline">
        &copy; {year} {brand} &middot; Lima, Perú &middot; Hecho con IA + código
      </p>
    </div>
  </div>
</footer>
