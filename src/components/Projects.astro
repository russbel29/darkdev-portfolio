---
const projects = [
  {
    title: 'Brigith & Perla Beauty House',
    category: 'Belleza',
    description: 'Landing page elegante para estudio de belleza en San Juan de Lurigancho. Diseño cálido, sección de servicios, galería de trabajos y reserva directa por WhatsApp.',
    stack: ['Astro', 'Tailwind', 'SEO'],
    image: '/brigith-perla-preview.png',
    link: 'https://brigith-perla-beauty.vercel.app/',
    plan: 'Plan Básico',
  },
  {
    title: 'Fogón Criollo',
    category: 'Gastronomía',
    description: 'Plataforma de reservas con integración de menú digital dinámico para restaurante criollo.',
    stack: ['Astro', 'Tailwind', 'API'],
    icon: 'restaurant',
    gradient: 'from-orange-950 to-red-900',
    link: null,
    plan: null,
  },
  {
    title: 'Estudio Lex',
    category: 'Legal',
    description: 'Landing corporativa de alta conversión para servicios de asesoría legal en San Isidro.',
    stack: ['Vanilla JS', 'SEO', 'Accessibility'],
    icon: 'gavel',
    gradient: 'from-slate-900 to-zinc-800',
    link: null,
    plan: null,
  },
];
---

<section id="proyectos" class="py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-reveal class="mb-12">
      <p class="text-sm text-secondary font-medium uppercase tracking-widest mb-2">Portafolio Seleccionado</p>
      <h2 class="text-4xl md:text-5xl font-heading font-bold tracking-tight">Proyectos recientes</h2>
    </div>

    <div class="grid gap-8 md:grid-cols-3">
      {projects.map((project) => (
        <div
          data-reveal
          class="group glass-card rounded-2xl overflow-hidden transition-all duration-500 hover:-translate-y-2 hover:neon-glow"
        >
          <!-- Preview image or gradient placeholder -->
          <div class={`relative h-48 overflow-hidden ${!project.image ? `bg-gradient-to-br ${project.gradient} flex items-center justify-center` : ''}`}>
            {project.image ? (
              <img
                src={project.image}
                alt={`Preview de ${project.title}`}
                class="w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <span class="material-symbols-outlined text-5xl text-white/60">{project.icon}</span>
            )}
            <span class="absolute top-3 left-3 bg-surface/80 text-on-surface-variant text-xs px-3 py-1 rounded-full backdrop-blur-sm">
              {project.category}
            </span>
            {project.plan && (
              <span class="absolute top-3 right-3 bg-secondary/90 text-white text-xs px-3 py-1 rounded-full backdrop-blur-sm font-medium">
                {project.plan}
              </span>
            )}
          </div>

          <!-- Content -->
          <div class="p-6 flex flex-col gap-4">
            <div>
              <h3 class="text-xl font-heading font-semibold text-on-surface mb-2">{project.title}</h3>
              <p class="text-sm text-on-surface-variant leading-relaxed">{project.description}</p>
            </div>

            <!-- Stack tags -->
            <div class="flex flex-wrap gap-2">
              {project.stack.map((tech) => (
                <span class="text-xs bg-surface-high text-on-surface-variant px-2.5 py-1 rounded-md">
                  {tech}
                </span>
              ))}
            </div>

            <!-- Link al sitio -->
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm text-secondary font-medium hover:underline mt-auto"
              >
                Ver sitio en vivo
                <span class="material-symbols-outlined text-base">open_in_new</span>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
