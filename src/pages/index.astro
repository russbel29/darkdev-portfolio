---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import Process from '../components/Process.astro';
import Pricing from '../components/Pricing.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const DATA = {
  brand: 'DarkDev',
  name: 'Russbel Celis Celestino',
  alias: 'Dark',
  city: 'Lima, Perú',
  whatsapp: '51966341277',
  whatsappMsg: 'Hola%20Dark%2C%20quiero%20una%20landing%20page',
  waLink: 'https://wa.me/51966341277?text=Hola%20Dark%2C%20quiero%20una%20landing%20page',
  year: '2025',
};
---

<BaseLayout
  title="DarkDev | Landing Pages para Negocios en Lima y LATAM"
  description="Diseño y desarrollo landing pages profesionales para negocios locales en Lima y Latinoamérica. Con IA, en menos de 5 días. Freelancer web — Russbel Celis."
>
  <Navbar brand={DATA.brand} waLink={DATA.waLink} />
  <Hero waLink={DATA.waLink} />
  <Projects />
  <Process waLink={DATA.waLink} />
  <Pricing waLink={DATA.waLink} />
  <About />
  <Contact waLink={DATA.waLink} />
  <Footer brand={DATA.brand} year={DATA.year} />
  <WhatsAppButton waLink={DATA.waLink} />
</BaseLayout>
